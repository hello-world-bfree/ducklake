statement ok
CREATE TABLE dl.s_view_base(a INTEGER)

statement ok
CREATE VIEW dl.alter_drop_view AS SELECT a FROM dl.s_view_base

statement ok con1
BEGIN

statement ok con2
BEGIN

statement ok con1
COMMENT ON VIEW dl.alter_drop_view IS 'comment-1'

statement ok con2
DROP VIEW dl.alter_drop_view

statement ok con1
COMMIT

statement error con2
COMMIT
----
<REGEX>:.*Transaction conflict.*drop view.*altered.*


